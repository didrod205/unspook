{
  "name": "unspook",
  "version": "0.1.0",
  "description": "Find & remove invisible, dangerous, and confusable characters hiding in your text — zero-width spaces, BOMs, bidi 'Trojan Source' controls, Unicode tag prompt-injection, homoglyphs, smart quotes & NBSP. Zero dependencies, runs locally.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "unspook": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "invisible-characters",
    "zero-width-space",
    "unicode",
    "sanitize",
    "homoglyph",
    "trojan-source",
    "bidi",
    "smart-quotes",
    "non-breaking-space",
    "text-cleaner",
    "prompt-injection",
    "security",
    "zero-dependency"
  ],
  "author": "didrod205 (https://github.com/didrod205)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/didrod205/unspook.git"
  },
  "bugs": {
    "url": "https://github.com/didrod205/unspook/issues"
  },
  "homepage": "https://didrod205.github.io/unspook/",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
